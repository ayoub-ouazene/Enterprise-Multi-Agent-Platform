# Application
APP_NAME=Enterprise Multi-Agent Platform
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@POOLED_HOST/DATABASE?ssl=require
ALEMBIC_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@DIRECT_HOST/DATABASE?ssl=require
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# Authentication placeholders for later steps
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Groq placeholders for later steps
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_ROUTER=llama-3.1-8b-instant
GROQ_MODEL_FAST=openai/gpt-oss-20b
GROQ_MODEL_REASONING=openai/gpt-oss-120b
GROQ_MODEL_REVIEWER=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=3
LLM_REQUEST_TIMEOUT_SECONDS=60

# Pinecone and company knowledge
PINECONE_API_KEY=
PINECONE_INDEX_NAME=enterprise-knowledge
PINECONE_INDEX_HOST=
PINECONE_EMBEDDING_MODEL=multilingual-e5-large
PINECONE_NAMESPACE_PREFIX=company
RAG_TOP_K=8
RAG_CHUNK_SIZE=400
RAG_CHUNK_OVERLAP=60

# File and workflow placeholders for later steps
UPLOAD_DIRECTORY=uploads
MAX_UPLOAD_SIZE_MB=25
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx,txt,csv,xlsx
ROUTER_MAX_CLARIFICATION_QUESTIONS=3
WORKFLOW_MAX_TOOL_RETRIES=2
WORKFLOW_REVIEW_MAX_REVISIONS=1
WORKFLOW_MAX_COLLABORATION_DEPTH=3
WORKFLOW_MAX_COLLABORATION_CALLS=6
WORKFLOW_MAX_COLLABORATION_ATTEMPTS=2
SSE_HEARTBEAT_SECONDS=15
